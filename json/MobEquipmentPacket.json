    "title": "MobEquipmentPacket",
    "description": "Mob Equipment. Changes to any mob's held/offhand item are fired from server to client with this packet. Clients also send this to the server when their held slot or its contents change.",
    "type": "object",
    "properties": {
        "Container ID": {
            "description": "Identifies which container the item belongs to, e.g. inventory or offhand.",
            "type": "integer",
            "x-underlying-type": "uint8",
            "x-serialization-options": [
                "Compression"
            ],
            "x-ordinal-index": 4,
            "minimum": 0.0,
            "maximum": 255.0
        },
        "Item": {
            "description": "The item stack being equipped. Send an empty descriptor to indicate no item.",
            "$ref": "#/definitions/1987673147",
            "x-ordinal-index": 1
        },
        "Selected Slot": {
            "description": "The hotbar slot that is currently selected by the player. Matches Slot for non-player mobs.",
            "type": "integer",
            "x-underlying-type": "uint8",
            "x-serialization-options": [
                "Compression"
            ],
            "x-ordinal-index": 3,
            "minimum": 0.0,
            "maximum": 255.0
        },
        "Slot": {
            "description": "The inventory slot index the item occupies within the container.",
            "type": "integer",
            "x-underlying-type": "uint8",
            "x-serialization-options": [
                "Compression"
            ],
            "x-ordinal-index": 2,
            "minimum": 0.0,
            "maximum": 255.0
        },
        "Target Runtime ID": {
            "description": "Runtime ID of the mob or player whose equipment is changing.",
            "$ref": "#/definitions/1750201151",
            "x-ordinal-index": 0
        }
    },
    "required": [
        "Container ID",
        "Item",
        "Selected Slot",
        "Slot",
        "Target Runtime ID"
    ],
