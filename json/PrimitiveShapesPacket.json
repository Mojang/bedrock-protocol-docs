    "definitions": {
        "2635068427": {
            "title": "PrimitiveShapeDataPayload",
            "type": "object",
            "properties": {
                "Attached To Entity ID": {
                    "description": "Runtime ID of the entity this shape is attached to.",
                    "$ref": "#/definitions/4257541248",
                    "x-ordinal-index": 9
                },
                "Color": {
                    "description": "Color (ARGB Hex string) of the debug shape.",
                    "$ref": "#/definitions/3702137727",
                    "x-ordinal-index": 7
                },
                "Dimension ID": {
                    "description": "Currently supported: (0 -> Overworld, 1 -> Nether, 2 -> The End, 3 -> Undefined)",
                    "$ref": "#/definitions/1586048219",
                    "x-ordinal-index": 8
                },
                "Extra Shape Data": {
                    "description": "Extra payload (variant) holding data specific to the type of shape (such as text string for the text shape).",
                    "default": null,
                    "oneOf": [
                        {
                            "type": "null",
                            "x-ordinal-index": 0
                        },
                        {
                            "$ref": "#/definitions/3614003324",
                            "x-ordinal-index": 1
                        },
                        {
                            "$ref": "#/definitions/3500005140",
                            "x-ordinal-index": 2
                        },
                        {
                            "$ref": "#/definitions/3663142120",
                            "x-ordinal-index": 3
                        },
                        {
                            "$ref": "#/definitions/1758265407",
                            "x-ordinal-index": 4
                        },
                        {
                            "$ref": "#/definitions/1119825038",
                            "x-ordinal-index": 5
                        }
                    ],
                    "x-control-value-type": "uint32",
                    "x-ordinal-index": 10
                },
                "Location": {
                    "description": "Vec3 location of the debug shape in the world.",
                    "$ref": "#/definitions/725374594",
                    "x-ordinal-index": 2
                },
                "Maximum Render Distance": {
                    "description": "The maximum distacne away that this shape will render for each client.",
                    "type": "number",
                    "x-underlying-type": "float",
                    "x-ordinal-index": 6
                },
                "NetworkId": {
                    "description": "uint64 network id used to identify the matching shape on the client as the server",
                    "type": "integer",
                    "x-underlying-type": "uint64",
                    "x-serialization-options": [
                        "Compression"
                    ],
                    "x-ordinal-index": 0,
                    "minimum": 0.0
                },
                "Rotation": {
                    "description": "Vec3 (Euler angles in radians, PYR) rotation of the debug shape in the world.",
                    "$ref": "#/definitions/725374594",
                    "x-ordinal-index": 4
                },
                "Scale": {
                    "description": "Float scale of the debug shape in the world.",
                    "type": "number",
                    "x-underlying-type": "float",
                    "x-ordinal-index": 3
                },
                "Shape Type": {
                    "title": "ScriptModuleMinecraft::ScriptPrimitiveShapeType",
                    "description": "Byte representing the type of debug shape (Line, Box, Sphere, Circle, Text).",
                    "type": "string",
                    "enum": [
                        "Line",
                        "Box",
                        "Sphere",
                        "Circle",
                        "Text",
                        "Arrow"
                    ],
                    "x-underlying-type": "uint8",
                    "x-serialization-options": [
                        "Enum-as-Value"
                    ],
                    "x-ordinal-index": 1
                },
                "Total Time Left": {
                    "description": "The total time left in seconds until this debug shape will be removed (0 meaning never).",
                    "type": "number",
                    "x-underlying-type": "float",
                    "x-ordinal-index": 5
                }
            },
            "required": [
                "Dimension ID",
                "NetworkId"
            ]
        },
