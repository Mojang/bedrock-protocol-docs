    "title": "InventoryTransactionPacket",
    "description": "Inventory Transaction. Sent for item interaction UI depending on if ItemStackNetManager is enabled as well as when the player uses items in gameplay. See ComplexInventoryTransaction::Type for more details.",
    "type": "object",
    "properties": {
        "Legacy Request ID": {
            "description": "Used when ItemStackNetManager is enabled. Identifies a legacy client item request. Negative, even values are valid. Zero indicates no legacy request.",
            "$ref": "#/definitions/2707715806",
            "x-ordinal-index": 0
        },
        "Legacy Set Item Slots": {
            "description": "Only present when Legacy Request ID is valid. Lists the open containers and their slot indices the client is requesting changes for.",
            "type": "array",
            "items": {
                "$ref": "#/definitions/2022041250"
            },
            "x-ordinal-index": 1
        },
        "Transaction": {
            "description": "The inventory transaction. The variant index encodes ComplexInventoryTransaction::Type (0=Normal, 1=Mismatch, 2=ItemUse, 3=ItemUseOnActor, 4=ItemRelease), matching the legacy wire format discriminator.",
            "oneOf": [
                {
                    "$ref": "#/definitions/2201057966",
                    "x-ordinal-index": 0
                },
                {
                    "$ref": "#/definitions/3043188243",
                    "x-ordinal-index": 1
                },
                {
                    "$ref": "#/definitions/1365757509",
                    "x-ordinal-index": 2
                },
                {
                    "$ref": "#/definitions/1628859409",
                    "x-ordinal-index": 3
                },
                {
                    "$ref": "#/definitions/1949982159",
                    "x-ordinal-index": 4
                }
            ],
            "x-control-value-type": "uint32",
            "x-ordinal-index": 2
        }
    },
    "required": [
        "Legacy Request ID",
        "Transaction"
    ],
